# ==============================================================================
# BidExpert - Variáveis de Ambiente para Vercel PROD
# Provider: Supabase PostgreSQL
# Branch Git: main
# ==============================================================================
# Template sem valores reais.
# Em Vercel, estas variáveis devem ser configuradas no escopo `production`.
# ==============================================================================

POSTGRES_PRISMA_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database?sslmode=require"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_YOUR_TOKEN"

NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://bidexpert.com.br"
NEXT_PUBLIC_DEFAULT_TENANT="prod"

NEXTAUTH_URL="https://bidexpert.com.br"
NEXTAUTH_SECRET="your-prod-secret-min-32-chars"
AUTH_SECRET="your-prod-auth-secret-min-32-chars"

TENANT_MODE="slug"
DEFAULT_TENANT_SLUG="prod"

PRISMA_SCHEMA="prisma/schema.postgresql.prisma"

RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

GOOGLE_GENAI_API_KEY="your-google-genai-api-key"

OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-endpoint"
OTEL_SERVICE_NAME="bidexpert-prod"