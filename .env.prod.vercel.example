# ==============================================================================
# BidExpert - VariĂ¡veis de Ambiente para Vercel PRODUĂ‡ĂƒO (main)
# ==============================================================================
# Este arquivo Ă© um TEMPLATE. NĂƒO COMMITAR com valores reais.
# Configure estas variĂ¡veis em: Vercel Dashboard â†’ Project Settings â†’ Environment Variables
# Environment: Production (branch: main)
#
# IMPORTANTE: Use as variĂ¡veis Neon injetadas pela integraĂ§Ă£o Neon no Vercel, ou
# configure manualmente com as URLs do banco de produĂ§Ă£o.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL (ambiente ProduĂ§Ă£o)
# ------------------------------------------------------------------------------
# URL com pgbouncer para uso pelo Prisma em runtime (OBRIGATĂ“RIO â€” schema url)
POSTGRES_PRISMA_URL="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require&pgbouncer=true"

# URL sem pooling â€” usada pelo Prisma CLI (migrate, db push, seed)
POSTGRES_URL_NON_POOLING="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require"

# URL direta (alias de compatibilidade)
DATABASE_URL="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require"

# URL com pooling genĂ©rico
POSTGRES_URL="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require&pgbouncer=true"

# ------------------------------------------------------------------------------
# NEXT.JS / APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://bidexpert.com.br"

# Workspace padrĂ£o para esta implantaĂ§Ă£o Vercel.
# Quando acessada sem subdomĂ­nio, a tela de login bloqueia automaticamente este workspace.
# Deve corresponder ao subdomain do tenant registrado no banco de dados de produĂ§Ă£o.
NEXT_PUBLIC_DEFAULT_TENANT="prod"
NEXT_PUBLIC_ENVIRONMENT="production"

# ------------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://bidexpert.com.br"
NEXTAUTH_SECRET="your-production-secret-key-min-32-chars"
AUTH_SECRET="your-production-auth-secret-min-32-chars"
SESSION_SECRET="your-production-session-secret-min-32-chars"

# ------------------------------------------------------------------------------
# PRISMA
# ------------------------------------------------------------------------------
PRISMA_SCHEMA="prisma-deploy/schema.postgresql.prisma"

# ------------------------------------------------------------------------------
# BLOB STORAGE - Vercel Blob
# ------------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_YOUR_TOKEN"

# ------------------------------------------------------------------------------
# EMAIL (Resend)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

# ------------------------------------------------------------------------------
# AI/LLM (Genkit)
# ------------------------------------------------------------------------------
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"

# ------------------------------------------------------------------------------
# OBSERVABILIDADE
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-endpoint"
OTEL_SERVICE_NAME="bidexpert-production"

# ============================================================
# AI Provider Configuration (Report Builder + Platform Q&A)
# ============================================================
# Options: "googleai" (default, requires GEMINI_API_KEY) | "ollama" (local, free)
AI_PROVIDER="googleai"

# Google Gemini (required when AI_PROVIDER=googleai)
GEMINI_API_KEY="your-gemini-api-key-here"

# Ollama (required when AI_PROVIDER=ollama)
# Install: https://ollama.ai — then: ollama pull llama3.2
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
