# ==============================================================================
# BidExpert - Variáveis de Ambiente para Vercel PRODUÇÃO (main)
# ==============================================================================
# Este arquivo é um TEMPLATE. NÃO COMMITAR com valores reais.
# Configure estas variáveis em: Vercel Dashboard → Project Settings → Environment Variables
# Environment: Production (branch: main)
#
# IMPORTANTE: Use as variáveis Neon injetadas pela integração Neon no Vercel, ou
# configure manualmente com as URLs do banco de produção.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL (ambiente Produção)
# ------------------------------------------------------------------------------
# URL com pgbouncer para uso pelo Prisma em runtime (OBRIGATÓRIO — schema url)
POSTGRES_PRISMA_URL="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require&pgbouncer=true"

# URL sem pooling — usada pelo Prisma CLI (migrate, db push, seed)
POSTGRES_URL_NON_POOLING="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require"

# URL direta (alias de compatibilidade)
DATABASE_URL="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require"

# URL com pooling genérico
POSTGRES_URL="postgresql://user:password@prod-host/bidexpert_prod?sslmode=require&pgbouncer=true"

# ------------------------------------------------------------------------------
# NEXT.JS / APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://bidexpert.com.br"

# Workspace padrão para esta implantação Vercel.
# Quando acessada sem subdomínio, a tela de login bloqueia automaticamente este workspace.
# Deve corresponder ao subdomain do tenant registrado no banco de dados de produção.
NEXT_PUBLIC_DEFAULT_TENANT="prod"
NEXT_PUBLIC_ENVIRONMENT="production"

# ------------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://bidexpert.com.br"
NEXTAUTH_SECRET="your-production-secret-key-min-32-chars"
AUTH_SECRET="your-production-auth-secret-min-32-chars"
SESSION_SECRET="your-production-session-secret-min-32-chars"

# ------------------------------------------------------------------------------
# PRISMA
# ------------------------------------------------------------------------------
PRISMA_SCHEMA="prisma-deploy/schema.postgresql.prisma"

# ------------------------------------------------------------------------------
# BLOB STORAGE - Vercel Blob
# ------------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_YOUR_TOKEN"

# ------------------------------------------------------------------------------
# EMAIL (Resend)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

# ------------------------------------------------------------------------------
# AI/LLM (Genkit)
# ------------------------------------------------------------------------------
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"

# ------------------------------------------------------------------------------
# OBSERVABILIDADE
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-endpoint"
OTEL_SERVICE_NAME="bidexpert-production"
