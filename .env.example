# ConfiguraĂ§Ăµes de E-mail
# Para desenvolvimento local, use Mailtrap (gratuito) ou SendGrid

# SendGrid (recomendado para produĂ§Ă£o)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# ConfiguraĂ§Ăµes de e-mail
CONTACT_EMAIL_FROM=noreply@bidexpert.com.br
CONTACT_EMAIL_TO=suporte@bidexpert.com.br

# SMTP alternativo (para desenvolvimento local com smtp4dev)
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Sentry Configuration (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=bidexpert-ai
SENTRY_AUTH_TOKEN=your-auth-token

# Vercel Log Drain Configuration (Alternative Error Monitoring)
LOG_DRAIN_SECRET=your-random-secret-here-min-32-chars
GITHUB_TOKEN=ghp_your_github_token_with_repo_permissions
# ============================================================
# AI Provider Configuration (Report Builder + Platform Q&A)
# ============================================================
# Options: "googleai" (default, requires GEMINI_API_KEY) | "ollama" (local, free)
AI_PROVIDER="googleai"

# Google Gemini (required when AI_PROVIDER=googleai)
GEMINI_API_KEY="your-gemini-api-key-here"

# Ollama (required when AI_PROVIDER=ollama)
# Install: https://ollama.ai — then: ollama pull llama3.2
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
