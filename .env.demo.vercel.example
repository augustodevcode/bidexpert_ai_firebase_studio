# ==============================================================================
# BidExpert - Variáveis de Ambiente para Vercel DEMO
# ==============================================================================
# Este arquivo é um TEMPLATE. NÃO COMMITAR com valores reais.
# Copie para .env.local e preencha os valores.
#
# IMPORTANTE: Use APENAS variáveis Neon (injetadas pela integração Neon no Vercel).
# NÃO configure a integração Prisma Postgres no Vercel — ela estava SUSPENSA
# (demo-bidexpert-prisma-cloud) e causava o erro "Provisioning integrations failed".
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL (via integração Neon no Vercel)
# Estas 4 variáveis são injetadas automaticamente pela integração Neon.
# ------------------------------------------------------------------------------
# URL direta do PostgreSQL (usada pelo Prisma CLI para migrate/seed e fallback de runtime)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# URL com pgbouncer para uso pela aplicação Prisma em runtime (OBRIGATÓRIO — schema url)
POSTGRES_PRISMA_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"

# URL com pooling genérico
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"

# URL sem pooling — usada pelo Prisma CLI (migrate, db push, seed) (OBRIGATÓRIO — schema directUrl)
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database?sslmode=require"
# VARIÁVEIS INJETADAS PELA INTEGRAÇÃO PRISMA (demo-bidexpert-prisma-cloud):
#   PRISMA_DEMO_POSTGRES_URL     → URL usada pelo datasource do schema PostgreSQL (url)
#   PRISMA_DEMO_PRISMA_DATABASE_URL → Alias Prisma da mesma URL
#   PRISMA_DEMO_DATABASE_URL     → URL Prisma Accelerate (quando ativo)
#
# VARIÁVEIS MANUAIS (configuradas via Neon ou outro provedor):
#   POSTGRES_URL_NON_POOLING     → URL direta sem pooling (usada como directUrl no schema)
#   POSTGRES_URL                 → URL com pooling (pgBouncer)
#   DATABASE_URL                 → NÃO usar no schema.postgresql.prisma — reservado para
#                                  scripts locais e seeds; conflita com a integração Prisma
#
# ATENÇÃO: Nunca configure DATABASE_URL como variável manual no Vercel enquanto a integração
# Prisma estiver ativa no projeto — isso causa "Provisioning integrations failed".
# O schema.postgresql.prisma usa PRISMA_DEMO_POSTGRES_URL + POSTGRES_URL_NON_POOLING.

# Injetadas pela integração Prisma (não editar manualmente no Vercel)
PRISMA_DEMO_POSTGRES_URL="postgresql://user:password@host/database?sslmode=require"
PRISMA_DEMO_PRISMA_DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
PRISMA_DEMO_DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# Configuradas manualmente (Neon ou outro provedor)
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database?sslmode=require"

# Apenas para scripts locais e seeds (não registrar como variável manual no Vercel)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ------------------------------------------------------------------------------
# BLOB STORAGE - Vercel Blob
# ------------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_YOUR_TOKEN"

# ------------------------------------------------------------------------------
# NEXT.JS / APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://bidexpert-demo.vercel.app"
NEXT_PUBLIC_TENANT_SLUG="demo"

# ------------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://bidexpert-demo.vercel.app"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"

# ------------------------------------------------------------------------------
# MULTI-TENANCY
# ------------------------------------------------------------------------------
TENANT_MODE="slug"
DEFAULT_TENANT_SLUG="demo"

# ------------------------------------------------------------------------------
# PRISMA
# ------------------------------------------------------------------------------
PRISMA_SCHEMA="prisma/schema.postgresql.prisma"

# ------------------------------------------------------------------------------
# EMAIL (Resend - opcional)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

# ------------------------------------------------------------------------------
# AI/LLM (Genkit - opcional)
# ------------------------------------------------------------------------------
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"

# ------------------------------------------------------------------------------
# OBSERVABILIDADE (opcional)
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-endpoint"
OTEL_SERVICE_NAME="bidexpert-demo"
