# ==============================================================================
# BidExpert - VariĂˇveis de Ambiente para Vercel DEMO
# Provider: Neon PostgreSQL
# Branch Git: demo-stable
# ==============================================================================
# Template sem valores reais.
# Em Vercel, a aplicaĂ§ĂŁo consome sempre as variĂˇveis genĂ©ricas abaixo; o isolamento
# da DEMO deve ser feito por escopo de environment/branch (`preview` + `demo-stable`).
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_PRISMA_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database?sslmode=require"
DATABASE_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"

# ------------------------------------------------------------------------------
# BLOB STORAGE - Vercel Blob
# ------------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_YOUR_TOKEN"

# ------------------------------------------------------------------------------
# NEXT.JS / APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://demo.bidexpert.com.br"
NEXT_PUBLIC_TENANT_SLUG="demo"
NEXT_PUBLIC_DEFAULT_TENANT="demo"

# Workspace padrĂŁo para esta implantaĂ§ĂŁo Vercel.
# Quando acessada sem subdomĂ­nio, a tela de login bloqueia automaticamente este workspace.
# Deve corresponder ao subdomain do tenant registrado no banco de dados.
NEXT_PUBLIC_DEFAULT_TENANT="demo"
NEXT_PUBLIC_ENVIRONMENT="demo"

# ------------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js
# NEXTAUTH_SECRET / AUTH_SECRET: o mesmo valor pode ser usado (AUTH_SECRET Ă© o
#   nome canĂ´nico no NextAuth v5; NEXTAUTH_SECRET Ă© mantido para compatibilidade).
# SESSION_SECRET: chave exclusiva para assinar cookies de sessĂŁo Iron Session.
# Todos devem ter pelo menos 32 caracteres aleatĂłrios.
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://demo.bidexpert.com.br"
NEXTAUTH_SECRET="your-demo-secret-key-min-32-chars"
AUTH_SECRET="your-demo-auth-secret-min-32-chars"
SESSION_SECRET="your-demo-session-secret-min-32-chars"

# ------------------------------------------------------------------------------
# MULTI-TENANCY
# ------------------------------------------------------------------------------
TENANT_MODE="slug"
DEFAULT_TENANT_SLUG="demo"

# ------------------------------------------------------------------------------
# PRISMA
# ------------------------------------------------------------------------------
PRISMA_SCHEMA="prisma-deploy/schema.postgresql.prisma"

# ------------------------------------------------------------------------------
# EMAIL (Resend - opcional)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

# ------------------------------------------------------------------------------
# AI/LLM (Genkit - opcional)
# ------------------------------------------------------------------------------
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"

# ------------------------------------------------------------------------------
# OBSERVABILIDADE (opcional)
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-endpoint"
OTEL_SERVICE_NAME="bidexpert-demo"

# ============================================================
# AI Provider Configuration (Report Builder + Platform Q&A)
# ============================================================
# Options: "googleai" (default, requires GEMINI_API_KEY) | "ollama" (local, free)
AI_PROVIDER="googleai"

# Google Gemini (required when AI_PROVIDER=googleai)
GEMINI_API_KEY="your-gemini-api-key-here"

# Ollama (required when AI_PROVIDER=ollama)
# Install: https://ollama.ai — then: ollama pull llama3.2
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
