			"command": "node .vscode/start-9005.js",
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": false
			},
			"problemMatcher": [],
			"isBackground": true,
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
