# ============================================================
# BidExpert - Template de Ambiente Isolado por Desenvolvedor
# ============================================================
# INSTRUÃ‡ÃƒO: Copie para .env.dev.<DEV_ID> e ajuste os valores.
# Exemplo: cp .env.dev.template .env.dev.augusto
#
# DEV_ID deve ser Ãºnico por desenvolvedor (ex: augusto, maria, joao)
# As portas sÃ£o calculadas automaticamente a partir do DEV_ID no compose.
# ============================================================

# Identificador Ãºnico do dev (sem espaÃ§os, lowercase)
DEV_ID=dev1

# Faixa de portas (cada dev usa faixa prÃ³pria)
# Dev1: app=9101 db=3401 mail=8201
# Dev2: app=9102 db=3402 mail=8202
# Dev3: app=9103 db=3403 mail=8203
# DevN: app=91XX db=34XX mail=82XX
APP_PORT=9101
DB_PORT=3401
MAIL_PORT=8201

# Database (cada dev tem seu schema isolado)
MYSQL_ROOT_PASSWORD=DevPassword2026
MYSQL_DATABASE=bidexpert_${DEV_ID}
DATABASE_URL=mysql://root:DevPassword2026@mysql-${DEV_ID}:3306/bidexpert_${DEV_ID}

# App
NODE_ENV=development
TENANT_SLUG=dev

# Playwright (dentro do container)
PLAYWRIGHT_BASE_URL=http://app-${DEV_ID}:3000
# Fora do container (host)
BASE_URL=http://localhost:${APP_PORT}

# Feature branch atual
GIT_BRANCH=

# ============================================================
# AI Provider Configuration (Report Builder + Platform Q&A)
# ============================================================
# Options: "googleai" (default, requires GEMINI_API_KEY) | "ollama" (local, free)
AI_PROVIDER="googleai"

# Google Gemini (required when AI_PROVIDER=googleai)
GEMINI_API_KEY="your-gemini-api-key-here"

# Ollama (required when AI_PROVIDER=ollama)
# Install: https://ollama.ai — then: ollama pull llama3.2
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
