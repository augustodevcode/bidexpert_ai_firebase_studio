# ==============================================================================
# BidExpert - VariĂ¡veis de Ambiente para Vercel HML (HomologaĂ§Ă£o)
# ==============================================================================
# Este arquivo Ă© um TEMPLATE. NĂƒO COMMITAR com valores reais.
# Configure estas variĂ¡veis em: Vercel Dashboard â†’ Project Settings â†’ Environment Variables
# Environment: Preview (branch: hml)
#
# IMPORTANTE: Use as variĂ¡veis Neon injetadas pela integraĂ§Ă£o Neon no Vercel, ou
# configure manualmente com as URLs do banco HML.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL (ambiente HML)
# ------------------------------------------------------------------------------
# URL com pgbouncer para uso pelo Prisma em runtime (OBRIGATĂ“RIO â€” schema url)
POSTGRES_PRISMA_URL="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require&pgbouncer=true"

# URL sem pooling â€” usada pelo Prisma CLI (migrate, db push, seed)
POSTGRES_URL_NON_POOLING="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require"

# URL direta (alias de compatibilidade)
DATABASE_URL="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require"

# URL com pooling genĂ©rico
POSTGRES_URL="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require&pgbouncer=true"

# ------------------------------------------------------------------------------
# NEXT.JS / APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://bidexpert-hml.vercel.app"

# Workspace padrĂ£o para esta implantaĂ§Ă£o Vercel.
# Quando acessada sem subdomĂ­nio, a tela de login bloqueia automaticamente este workspace.
# Deve corresponder ao subdomain do tenant registrado no banco de dados.
NEXT_PUBLIC_DEFAULT_TENANT="hml"
NEXT_PUBLIC_ENVIRONMENT="hml"

# ------------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js
# NEXTAUTH_SECRET / AUTH_SECRET: o mesmo valor pode ser usado (AUTH_SECRET Ă© o
#   nome canĂ´nico no NextAuth v5; NEXTAUTH_SECRET Ă© mantido para compatibilidade).
# SESSION_SECRET: chave exclusiva para assinar cookies de sessĂ£o Iron Session.
# Todos devem ter pelo menos 32 caracteres aleatĂ³rios.
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://bidexpert-hml.vercel.app"
NEXTAUTH_SECRET="your-hml-secret-key-min-32-chars"
AUTH_SECRET="your-hml-auth-secret-min-32-chars"
SESSION_SECRET="your-hml-session-secret-min-32-chars"

# ------------------------------------------------------------------------------
# PRISMA
# ------------------------------------------------------------------------------
PRISMA_SCHEMA="prisma-deploy/schema.postgresql.prisma"

# ------------------------------------------------------------------------------
# EMAIL (Resend - opcional)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

# ------------------------------------------------------------------------------
# AI/LLM (Genkit - opcional)
# ------------------------------------------------------------------------------
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"

# ============================================================
# AI Provider Configuration (Report Builder + Platform Q&A)
# ============================================================
# Options: "googleai" (default, requires GEMINI_API_KEY) | "ollama" (local, free)
AI_PROVIDER="googleai"

# Google Gemini (required when AI_PROVIDER=googleai)
GEMINI_API_KEY="your-gemini-api-key-here"

# Ollama (required when AI_PROVIDER=ollama)
# Install: https://ollama.ai — then: ollama pull llama3.2
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
