# ==============================================================================
# BidExpert - Variáveis de Ambiente para Vercel HML (Homologação)
# ==============================================================================
# Este arquivo é um TEMPLATE. NÃO COMMITAR com valores reais.
# Configure estas variáveis em: Vercel Dashboard → Project Settings → Environment Variables
# Environment: Preview (branch: hml)
#
# IMPORTANTE: Use as variáveis Neon injetadas pela integração Neon no Vercel, ou
# configure manualmente com as URLs do banco HML.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL (ambiente HML)
# ------------------------------------------------------------------------------
# URL com pgbouncer para uso pelo Prisma em runtime (OBRIGATÓRIO — schema url)
POSTGRES_PRISMA_URL="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require&pgbouncer=true"

# URL sem pooling — usada pelo Prisma CLI (migrate, db push, seed)
POSTGRES_URL_NON_POOLING="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require"

# URL direta (alias de compatibilidade)
DATABASE_URL="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require"

# URL com pooling genérico
POSTGRES_URL="postgresql://user:password@hml-host/bidexpert_hml?sslmode=require&pgbouncer=true"

# ------------------------------------------------------------------------------
# NEXT.JS / APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://bidexpert-hml.vercel.app"

# Workspace padrão para esta implantação Vercel.
# Quando acessada sem subdomínio, a tela de login bloqueia automaticamente este workspace.
# Deve corresponder ao subdomain do tenant registrado no banco de dados.
NEXT_PUBLIC_DEFAULT_TENANT="hml"
NEXT_PUBLIC_ENVIRONMENT="hml"

# ------------------------------------------------------------------------------
# AUTHENTICATION - NextAuth.js
# NEXTAUTH_SECRET / AUTH_SECRET: o mesmo valor pode ser usado (AUTH_SECRET é o
#   nome canônico no NextAuth v5; NEXTAUTH_SECRET é mantido para compatibilidade).
# SESSION_SECRET: chave exclusiva para assinar cookies de sessão Iron Session.
# Todos devem ter pelo menos 32 caracteres aleatórios.
# ------------------------------------------------------------------------------
NEXTAUTH_URL="https://bidexpert-hml.vercel.app"
NEXTAUTH_SECRET="your-hml-secret-key-min-32-chars"
AUTH_SECRET="your-hml-auth-secret-min-32-chars"
SESSION_SECRET="your-hml-session-secret-min-32-chars"

# ------------------------------------------------------------------------------
# PRISMA
# ------------------------------------------------------------------------------
PRISMA_SCHEMA="prisma-deploy/schema.postgresql.prisma"

# ------------------------------------------------------------------------------
# EMAIL (Resend - opcional)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_YOUR_API_KEY"
EMAIL_FROM="noreply@bidexpert.com.br"

# ------------------------------------------------------------------------------
# AI/LLM (Genkit - opcional)
# ------------------------------------------------------------------------------
GOOGLE_GENAI_API_KEY="your-google-genai-api-key"
