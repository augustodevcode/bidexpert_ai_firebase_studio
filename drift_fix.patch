+  await page.click('button[type="submit"]');
+  
+  await new Promise(r => setTimeout(r, 6000));
+  
+  console.log("COOKIES NOW:", await context.cookies());
+  await page.screenshot({ path: 'login7_after.png' });
+
+  await browser.close();
+})();
