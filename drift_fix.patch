+  
+  await new Promise(r => setTimeout(r, 4000));
+  
+  await page.screenshot({ path: 'login7.png' });
+
+  // login manually
+  console.log('filling inputs');
+  await page.fill('input[name="email"]', 'admin@bidexpert.com.br');
